namespace App {
    function ClampNumber[T restrict[UInt, Int, Float]](value : T, limit : T) : T {
        if value > limit {
            return limit;
        }
        return value;
    }

    function Start() : Int {
        local mut T restrict[UInt, Int, Float] numeric = 42;
        numeric = ClampNumber(100, 64);
        local T restrict[UInt, Int, Float] smaller = ClampNumber(5, 64);
        print("restricted", numeric, smaller);
        return numeric + smaller;
    }
}
