{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Klang",
  "scopeName": "source.klang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#imports" },
    { "include": "#namespace" },
    { "include": "#function-declaration" },
    { "include": "#variable-declaration" },
    { "include": "#hooks" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.klang",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.klang",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.klang" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.klang" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.klang",
              "match": "\\\\([\\\\\"'nrt])"
            },
            {
              "name": "invalid.illegal.escape.klang",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "chars": {
      "patterns": [
        {
          "name": "string.quoted.single.klang",
          "begin": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.klang" }
          },
          "end": "'",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.klang" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.klang",
              "match": "\\\\([\\\\\"'nrt])"
            },
            {
              "name": "invalid.illegal.escape.klang",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.klang",
          "match": "\\b(import)\\s+(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.control.import.klang" },
            "2": { "name": "string.quoted.double.import.klang" }
          }
        }
      ]
    },
    "namespace": {
      "patterns": [
        {
          "name": "meta.namespace.klang",
          "match": "\\b(namespace)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.namespace.klang" },
            "2": { "name": "entity.name.namespace.klang" }
          }
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "name": "meta.alias-function.klang",
          "match": "\\b(alias)\\s+(function)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.alias.klang" },
            "2": { "name": "keyword.declaration.function.klang" },
            "3": { "name": "entity.name.type.alias.klang" }
          }
        },
        {
          "name": "meta.function-group.klang",
          "match": "\\b(function_group)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.function-group.klang" },
            "2": { "name": "entity.name.function-group.klang" }
          }
        },
        {
          "name": "meta.trait.klang",
          "match": "\\b(trait)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.trait.klang" },
            "2": { "name": "entity.name.type.trait.klang" }
          }
        },
        {
          "name": "meta.impl.klang",
          "match": "\\b(impl)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(for)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.impl.klang" },
            "2": { "name": "entity.name.type.trait.klang" },
            "3": { "name": "keyword.control.for.klang" },
            "4": { "name": "entity.name.type.klang" }
          }
        },
        {
          "name": "meta.region.klang",
          "match": "\\b(region)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.region.klang" },
            "2": { "name": "entity.name.region.klang" }
          }
        },
        {
          "name": "meta.function.klang",
          "match": "\\b(?:(async|lazy|inner)\\s+)?(function)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()",
          "captures": {
            "1": { "name": "storage.modifier.function.klang" },
            "2": { "name": "keyword.declaration.function.klang" },
            "3": { "name": "entity.name.function.klang" },
            "4": { "name": "punctuation.section.parameters.begin.klang" }
          }
        },
        {
          "name": "keyword.declaration.function.lambda.klang",
          "match": "\\bfun\\b(?=\\s*(?:\\[|\\())"
        }
      ]
    },
    "variable-declaration": {
      "patterns": [
        {
          "name": "meta.variable.declaration.klang",
          "match": "\\b(global|local)\\s+(?:(mut)\\s+)?([A-Za-z_][A-Za-z0-9_]*(?:\\[[^\\]]+\\])?)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.scope.klang" },
            "2": { "name": "storage.modifier.mutability.klang" },
            "3": { "name": "storage.type.klang" },
            "4": { "name": "variable.other.readwrite.klang" }
          }
        },
        {
          "name": "meta.variable.declaration.inferred.klang",
          "match": "\\b(let)\\s+(mut)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.scope.local.klang" },
            "2": { "name": "storage.modifier.mutability.klang" },
            "3": { "name": "variable.other.readwrite.klang" }
          }
        },
        {
          "name": "meta.variable.declaration.inferred.klang",
          "match": "\\b(let|val|var|const)\\s+(?:size\\s+)?([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.scope.inferred.klang" },
            "2": { "name": "variable.other.readwrite.klang" }
          }
        }
      ]
    },
    "hooks": {
      "patterns": [
        {
          "name": "keyword.control.hook.klang",
          "match": "\\[(new|delete|side_effects)\\]"
        },
        {
          "name": "keyword.control.extend.klang",
          "match": "#extend\\b"
        },
        {
          "name": "support.function.compiler.klang",
          "match": "#(?:region|sizeof)\\b"
        },
        {
          "name": "storage.modifier.annotation.deprecated.klang",
          "match": "@deprecated(?:\\([^)]*\\))?"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.klang",
          "match": "\\b(if|then|else|unless|for|while|do|do_while|end|return|break|continue|try|catch|throw|case|partial|await|import|namespace|region|alias|call|inner|function_group)\\b"
        },
        {
          "name": "storage.modifier.klang",
          "match": "\\b(global|local|let|var|val|const|mut|export|async|lazy)\\b"
        },
        {
          "name": "keyword.operator.word.klang",
          "match": "\\b(and|or|xor|not|is|as|in)\\b"
        },
        {
          "name": "keyword.operator.ownership.klang",
          "match": "\\b(move|copy|clone)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "meta.type.sizeof.klang",
          "match": "\\b(Int|UInt|String|Float|Bool|Char|Map|List|Table|Option|Result|Complex|SIMD|Function|Awaitable|Iterator|Coroutine|Thread|Atomic|Any|T|Args|Program|BuildSystem|WorkSpace|JSModule|JSCall|Box|Ref|RefMut|RefCell|HeapAllocator|RegionAllocator|BumpAllocator|ArenaAllocator)(\\.)(sizeof)\\b",
          "captures": {
            "1": { "name": "storage.type.primitive.klang" },
            "2": { "name": "punctuation.accessor.klang" },
            "3": { "name": "support.variable.sizeof.klang" }
          }
        },
        {
          "name": "storage.type.primitive.klang",
          "match": "\\b(Int|UInt|String|Float|Bool|Char|Map|List|Table|Option|Result|Complex|SIMD|Function|Awaitable|Iterator|Coroutine|Thread|Atomic|Any|T|Args|Program|BuildSystem|WorkSpace|JSModule|JSCall|Box|Ref|RefMut|RefCell|HeapAllocator|RegionAllocator|BumpAllocator|ArenaAllocator)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.klang",
          "match": "\\b(True|False)\\b"
        },
        {
          "name": "constant.language.option-result.klang",
          "match": "\\b(None|Some|Ok|Err|Result)\\b"
        },
        {
          "name": "constant.language.default.klang",
          "match": "\\bDEFAULT\\b|\\.(DEFAULT)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.klang",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.klang",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "meta.function-call.qualified.klang",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(::|\\.)([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.namespace.klang" },
            "2": { "name": "punctuation.accessor.klang" },
            "3": { "name": "entity.name.function.klang" }
          }
        },
        {
          "name": "entity.name.function.call.klang",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.klang",
          "match": "(==|!=|>=|<=|>|<)"
        },
        {
          "name": "keyword.operator.assignment.klang",
          "match": "(:=|\\+=|-=|\\*=|/=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.klang",
          "match": "(\\*\\*|//|[+\\-*/%])"
        },
        {
          "name": "keyword.operator.pipe.klang",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.null-safety.klang",
          "match": "[!?]"
        },
        {
          "name": "keyword.operator.arrow.klang",
          "match": "(->|=>)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.klang",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.klang",
          "match": ","
        },
        {
          "name": "punctuation.definition.type.return.klang",
          "match": ":"
        },
        {
          "name": "punctuation.section.block.klang",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.brackets.klang",
          "match": "[\\[\\]()]"
        },
        {
          "name": "punctuation.accessor.klang",
          "match": "\\."
        }
      ]
    }
  }
}
