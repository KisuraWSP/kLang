-- file: aether_resonance.klang

-- First-class modifier functions
function InvertPolarity(val : Int) : Int { return val * -1; }
function Amplify(val : Int) : Int { return val + 5; }
function Dampen(val : Int) : Int { 
    unless val > 10 { return val; } 
    else { return val - 2; }
}

-- High-order function that applies a list of functions to a list of integers
function ApplyResonance(crystals : List[Int], operations : List[T]) : List[Int] {
    local Int crystalCount = len(crystals);
    local Int opCount = len(operations);
    local mut List[Int] stabilized = crystals;
    
    for i := range(crystalCount) {
        for j := range(opCount) {
            -- Fetching the function from the list
            local T currentOp = operations[j];
            -- Invoking the generic type as a function on the specific list item
            stabilized[i] = currentOp(stabilized[i]);
        }
    }
    
    return stabilized;
}

function Main() : Int {
    local List[Int] rawCrystals = [5, 0 - 2, 12, 8];
    local List[T] actionQueue = [Amplify, Dampen, InvertPolarity];
    
    -- Applying the set of operations at the same time
    local List[Int] finalState = ApplyResonance(rawCrystals, actionQueue);
    
    -- Check winning condition (Expected: [-10, -3, -15, -13])
    unless finalState[0] == 0 - 10 {
        print("Game Over: Resonance cascade failure.");
        return 1;
    } else {
        print("Level Cleared: Crystals stabilized.");
        return 0;
    }
}
