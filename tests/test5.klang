global mut Int globalDepth = 0;

function TraverseLabyrinth(maxDepth : Int) : Bool {
    local mut Int currentPath = 0;
    
    -- Using the evaluation assignment syntax
    while info := currentPath < maxDepth {
        -- INTENTIONAL SHADOWING: The parser must isolate this from the outer 'currentPath'
        local mut Int innerPath = 999; 
        
        for i := range(10) {
            unless i > 5 {
                globalDepth += 1;
                
                -- Deeply nested do_while inside an unless
                do_while j := range(3) {
                    innerPath -= 1; 
                    if innerPath == 990 break;
                }
            } else {
                globalDepth -= 1;
            }
        }
        
        -- If scoping is broken, this loop runs forever.
        -- If scoping is correct, this increments the outer variable.
        currentPath += 1;
        
        -- Let's force a break to prevent actual infinite loops during your testing
        if globalDepth > 50 break;
    }
    
    return True;
}
