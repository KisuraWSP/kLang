    @deprecated("Use MakeStringList instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function make_string_list(size : Int, defaultValue : String = "") : List[String] {
        local mut List[String] result;
        local mut Int index = 0;

        while index < size {
            result[len(result)] = defaultValue;
            index += 1;
        }

        return result;
    }

