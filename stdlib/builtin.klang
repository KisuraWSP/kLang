    --- Signature: function append(values : List[T], value : T) : List[T]
    --- Returns: List[T].
    --- Summary: Combines or extends Klang value(s) for the append operation.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Append(values : List[T], value : T) : List[T] {
        return append(values, value);
    }

    @deprecated("Use Append instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function append(values : List[T], value : T) : List[T] {
        local mut List[T] result = clone values;
        result[len(result)] = value;
        return result;
    }

    --- Signature: function append_all(left : List[T], right : List[T]) : List[T]
    --- Returns: List[T].
    --- Summary: Combines or extends Klang value(s) for the append all operation.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function AppendAll(left : List[T], right : List[T]) : List[T] {
        return append_all(left, right);
    }

    @deprecated("Use AppendAll instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function append_all(left : List[T], right : List[T]) : List[T] {
        local mut List[T] result = clone left;
        local mut Int index = 0;

        while index < len(right) {
            result[len(result)] = right[index];
            index += 1;
        }

        return result;
    }

