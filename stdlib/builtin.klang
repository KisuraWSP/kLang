    --- Signature: function try_or(action : Function[T], fallback : T) : T
    --- Returns: T.
    --- Summary: Performs the try or control-flow or runtime I/O operation.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function TryOr(action : Function[T], fallback : T) : T {
        return try_or(action, fallback);
    }

    @deprecated("Use TryOr instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function try_or(action : Function[T], fallback : T) : T {
        try {
            return action();
        } catch err {
            return fallback;
        }
    }

