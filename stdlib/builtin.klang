    --- Signature: function len_value(value : T) : Int
    --- Returns: Int.
    --- Summary: Provides the stdlib len value operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function LenValue(value : T) : Int {
        return len_value(value);
    }

    @deprecated("Use LenValue instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function len_value(value : T) : Int {
        if debug_type(value) == "String" {
            return len(value as String);
        }

        return 0;
    }

    --- Signature: function make_int_list(size : Int, defaultValue : Int = 0) : List[Int]
    --- Returns: List[Int].
    --- Summary: Creates or initializes make int list with the supplied Klang value(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function MakeIntList(size : Int, defaultValue : Int = 0) : List[Int] {
        return make_int_list(size, defaultValue);
    }

    @deprecated("Use MakeIntList instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function make_int_list(size : Int, defaultValue : Int = 0) : List[Int] {
        local mut List[Int] result;
        local mut Int index = 0;

        while index < size {
            result[len(result)] = defaultValue;
            index += 1;
        }

        return result;
    }

    --- Signature: function make_string_list(size : Int, defaultValue : String = "") : List[String]
    --- Returns: List[String].
    --- Summary: Creates or initializes make string list with the supplied Klang value(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function MakeStringList(size : Int, defaultValue : String = "") : List[String] {
