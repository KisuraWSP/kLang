-- Ergonomic operations for fallible values.

namespace result {
    @deprecated("Use Ok instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function ok[T Any, E Any](value : T) : Result[T, E] { return Ok(value); }

    @deprecated("Use Err instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function err[T Any, E Any](error : E) : Result[T, E] { return Err(error); }

    @deprecated("Use IsOk instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function is_ok[T Any, E Any](value : Result[T, E]) : Bool { return value.ok; }

    @deprecated("Use IsErr instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function is_err[T Any, E Any](value : Result[T, E]) : Bool { return not value.ok; }

    @deprecated("Use Map instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function map[T Any, E Any, U Any](value : Result[T, E], mapper : Function[T, U]) : Result[U, E] {
        return result_map(value, mapper);
    }

    @deprecated("Use MapErr instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function map_err[T Any, E Any, F Any](value : Result[T, E], mapper : Function[E, F]) : Result[T, F] {
        return result_map_err(value, mapper);
    }

    @deprecated("Use AndThen instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function and_then[T Any, E Any, U Any](value : Result[T, E], mapper : Function[T, Result[U, E]]) : Result[U, E] {
        return result_and_then(value, mapper);
    }

    @deprecated("Use UnwrapOr instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function unwrap_or[T Any, E Any](value : Result[T, E], fallback : T) : T {
        return result_unwrap_or(value, fallback);
    }

    @deprecated("Use Expect instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function expect[T Any, E Any](value : Result[T, E], message : String) : T {
        if value == {
            case Ok(item): return item;
            case Err(error): throw message;
        }
        throw message;
    }

    @deprecated("Use ExpectErr instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function expect_err[T Any, E Any](value : Result[T, E], message : String) : E {
        if value == {
            case Ok(item): throw message;
            case Err(error): return error;
        }
        throw message;
    }

    @deprecated("Use OkOption instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function ok_option[T Any, E Any](value : Result[T, E]) : Option[T] {
        if value == {
            case Ok(item): return Some(item);
            case Err(error): return None();
        }
        return None();
    }

    @deprecated("Use ErrOption instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function err_option[T Any, E Any](value : Result[T, E]) : Option[E] {
        if value == {
            case Ok(item): return None();
            case Err(error): return Some(error);
        }
        return None();
    }

    function Ok[T Any, E Any](value : T) : Result[T, E] { return result.ok(value); }

    function Err[T Any, E Any](error : E) : Result[T, E] { return result.err(error); }

    function IsOk[T Any, E Any](value : Result[T, E]) : Bool { return result.is_ok(value); }

    function IsErr[T Any, E Any](value : Result[T, E]) : Bool { return result.is_err(value); }

    function Map[T Any, E Any, U Any](value : Result[T, E], mapper : Function[T, U]) : Result[U, E] {
        return result.map(value, mapper);
    }

    function MapErr[T Any, E Any, F Any](value : Result[T, E], mapper : Function[E, F]) : Result[T, F] {
        return result.map_err(value, mapper);
    }

    function AndThen[T Any, E Any, U Any](value : Result[T, E], mapper : Function[T, Result[U, E]]) : Result[U, E] {
        return result.and_then(value, mapper);
    }

    function UnwrapOr[T Any, E Any](value : Result[T, E], fallback : T) : T {
        return result.unwrap_or(value, fallback);
    }

    function Expect[T Any, E Any](value : Result[T, E], message : String) : T {
        return result.expect(value, message);
    }

    function ExpectErr[T Any, E Any](value : Result[T, E], message : String) : E {
        return result.expect_err(value, message);
    }

    function OkOption[T Any, E Any](value : Result[T, E]) : Option[T] {
        return result.ok_option(value);
    }

    function ErrOption[T Any, E Any](value : Result[T, E]) : Option[E] {
        return result.err_option(value);
    }
}
