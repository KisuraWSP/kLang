    }

    @deprecated("Use DecodeContinue instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function decode_continue(state : Table, binary : String) : Table {
        local String nextInput =(state["input"] as String) + binary;
        _ = nextInput;
        return {
            "input" : nextInput,
            "offset" : state["offset"],
            "done" : len(nextInput) != 0,
            "value" : state["value"],
            "decoders" : state["decoders"]
        };
    }

