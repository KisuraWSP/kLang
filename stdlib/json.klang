-- Typed JSON and native-value serialization backed by Klang's Go runtime.
-- The older String encoder functions remain as compatibility helpers.

namespace json {
    private function with_code[T Any](value : Result[T, String], code : Atom) : Result[T, Atom] {
        if value == {
            case Ok(item): return Ok(item);
            case Err(message):
                _ = message;
                return Err(code);
        }
        return Err(code);
    }

    --- Parses one complete JSON value without throwing.
    @deprecated("Use Parse instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function parse(source : String) : Result[JSON, Atom] {
        return json.with_code(json_parse(source), :json_parse_failed);
    }

    --- Parses one complete JSON value or raises a positioned runtime error.
    @deprecated("Use MustParse instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function must_parse(source : String) : JSON {
        return JSON(source);
    }

    --- Serializes any supported Klang value to canonical compact JSON text.
    @deprecated("Use Stringify instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function stringify(value : T) : String {
        return json_stringify(value);
    }

    --- Safely serializes Table, List, primitive, JSON, Option, enum, or alias struct values.
    @deprecated("Use Serialize instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function serialize(value : T) : Result[String, Atom] {
        return json.with_code(json_encode(value), :json_encode_failed);
    }

    --- Safely decodes JSON objects to Table, arrays to List, and scalars to native values.
    @deprecated("Use Deserialize instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function deserialize(source : String) : Result[T, Atom] {
        return json.with_code(json_decode(source), :json_decode_failed);
    }

    @deprecated("Use Valid instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function valid(source : String) : Bool {
        return parse(source).ok;
    }

    @deprecated("Use DeserializeOr instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function deserialize_or(source : String, fallback : T) : T {
        return result_unwrap_or(deserialize(source), fallback);
    }

    --- Returns an object field without raising when the field is absent.
    @deprecated("Use GetField instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function get_field(value : JSON, key : String) : Option[JSON] {
