        }

        return default_formatter;
    }

    --- Signature: function from_binary_fun() : Function[String, String]
    --- Returns: Function[String, String].
    --- Summary: Provides the stdlib from binary fun operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function from_binary_fun() : Function[String, String] {
        --- Signature: function from_binary(binary : String) : String
        --- Returns: String.
        --- Summary: Provides the stdlib from binary operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function from_binary(binary : String) : String {
            return binary;
        }

        return from_binary;
    }

    --- Signature: function decode_value(binary : String) : Result[String, String]
    --- Returns: Result[String, String].
    --- Summary: Reads, locates, or decodes decode value from the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function decode_value(binary : String) : Result[String, String] {
        if len(binary) == 0 {
            return Err("json decode expected a value");
        }

        local Result[JSON, String] parsed = parse(binary);
        if parsed.ok {
            return Ok(stringify(parsed.value));
        }
        return Err("json decode expected valid JSON");
    }

    --- Signature: function decode(binary : String, acc0 : String = "", decoderTable : Table = decoders()) : Result[String, String]
    --- Returns: Result[String, String].
    --- Summary: Reads, locates, or decodes decode from the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function decode(binary : String, acc0 : String = "", decoderTable : Table = decoders()) : Result[String, String] {
        local mut String input = acc0 + binary;
        if table_has(decoderTable, "from_binary") {
            local Function[String, String] fromBinary = decoderTable["from_binary"];
            input = fromBinary(input);
        }

        return decode_value(input);
    }

    --- Signature: function decode_start(binary : String, acc : String = "", decoderTable : Table = decoders()) : Table
    --- Returns: Table.
    --- Summary: Reads, locates, or decodes decode start from the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function decode_start(binary : String, acc : String = "", decoderTable : Table = decoders()) : Table {
        _ = binary;
        _ = acc;
        _ = decoderTable;
        return {
            "input" : acc + binary,
            "offset" : 0,
            "done" : len(binary) != 0,
            "value" : "",
            "decoders" : decoderTable
        };
    }

    --- Signature: function decode_continue(state : Table, binary : String) : Table
    --- Returns: Table.
    --- Summary: Reads, locates, or decodes decode continue from the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function decode_continue(state : Table, binary : String) : Table {
        local String nextInput =(state["input"] as String) + binary;
        _ = nextInput;
        return {
            "input" : nextInput,
            "offset" : state["offset"],
            "done" : len(nextInput) != 0,
            "value" : state["value"],
            "decoders" : state["decoders"]
        };
    }

    --- Signature: function encode(value : T, encodeFn : Function[T, String] = encoder()) : String
    --- Returns: String.
    --- Summary: Builds, writes, or formats encode using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function encode(value : T, encodeFn : Function[T, String] = encoder()) : String {
        _ = value;
        return encode_value(value, encodeFn);
    }

    --- Signature: function encode_atom(value : Bool) : String
    --- Returns: String.
    --- Summary: Builds, writes, or formats encode atom using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function encode_atom(value : Bool) : String {
        return Bool(value);
    }

    --- Signature: function encode_binary(value : String) : String
    --- Returns: String.
    --- Summary: Builds, writes, or formats encode binary using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function encode_binary(value : String) : String {
        _ = value;
        return "\"" + value + "\"";
    }

    --- Signature: function encode_binary_escape_all(value : String) : String
    --- Returns: String.
    --- Summary: Builds, writes, or formats encode binary escape all using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function encode_binary_escape_all(value : String) : String {
        return encode_binary(value);
    }

    --- Signature: function encode_float(value : Float) : String
    --- Returns: String.
    --- Summary: Builds, writes, or formats encode float using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function encode_float(value : Float) : String {
        return stringify(must_parse(value as String));
    }

    --- Signature: function encode_integer(value : Int) : String
    --- Returns: String.
    --- Summary: Builds, writes, or formats encode integer using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function encode_integer(value : Int) : String {
        return stringify(must_parse(value as String));
    }

    --- Signature: function encode_key_value_list(list : List[Table], encodeFn : Function[String, String] = encode_binary) : String
    --- Returns: String.
    --- Summary: Builds, writes, or formats encode key value list using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function encode_key_value_list(list : List[Table], encodeFn : Function[String, String] = encode_binary) : String {
        local mut String state = "{";
        local mut Int index = 0;

        while index < len(list) {
            local Table pair = list[index];
            local String key = pair["key"] as String;
            local String value = encodeFn(pair["value"] as String);

            if state == "{" {
                state = state + encode_binary(key) + ":" + value;
            } else {
                state = state + "," + encode_binary(key) + ":" + value;
            }

            index += 1;
        }

        return state + "}";
    }

    --- Signature: function encode_key_value_list_checked(list : List[Table], encodeFn : Function[String, String] = encode_binary) : Result[String, String]
    --- Returns: Result[String, String].
    --- Summary: Builds, writes, or formats encode key value list checked using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function encode_key_value_list_checked(list : List[Table], encodeFn : Function[String, String] = encode_binary) : Result[String, String] {
        local mut Int index = 0;

        while index < len(list) {
            local Table pair = list[index];
            if not table_has(pair, "key") {
                return Err("json object pair is missing key");
            }
            if not table_has(pair, "value") {
                return Err("json object pair is missing value");
            }
            index += 1;
        }

        return Ok(encode_key_value_list(list, encodeFn));
    }

    --- Signature: function encode_list(list : List[String], encodeFn : Function[String, String] = encode_binary) : String
    --- Returns: String.
    --- Summary: Builds, writes, or formats encode list using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function encode_list(list : List[String], encodeFn : Function[String, String] = encode_binary) : String {
        local mut String state = "[";
        local mut Int index = 0;

        while index < len(list) {
            local String value = encodeFn(list[index]);

            if state == "[" {
                state = state + value;
            } else {
                state = state + "," + value;
            }

            index += 1;
        }

        return state + "]";
    }

    --- Signature: function encode_map(value : Table, encodeFn : Function[String, String] = encode_binary) : String
    --- Returns: String.
    --- Summary: Builds, writes, or formats encode map using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function encode_map(value : Table, encodeFn : Function[String, String] = encode_binary) : String {
        _ = encodeFn;
        if table_has(value, "key") and table_has(value, "value") {
            return "{" + encode_binary(value["key"] as String) + ":" + encodeFn(value["value"] as String) + "}";
        }

        return "{}";
    }

    --- Signature: function encode_map_checked(value : Table, encodeFn : Function[String, String] = encode_binary) : Result[String, String]
    --- Returns: Result[String, String].
    --- Summary: Builds, writes, or formats encode map checked using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function encode_map_checked(value : Table, encodeFn : Function[String, String] = encode_binary) : Result[String, String] {
        if table_has(value, "key") and table_has(value, "value") {
            return Ok(encode_map(value, encodeFn));
        }

        return Err("json map requires key and value fields");
    }

    --- Signature: function encode_value(value : T, encodeFn : Function[T, String]) : String
    --- Returns: String.
    --- Summary: Builds, writes, or formats encode value using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function encode_value(value : T, encodeFn : Function[T, String]) : String {
        return encodeFn(value);
    }

    --- Signature: function format_options(indent : String = "  ") : Table
    --- Returns: Table.
    --- Summary: Builds, writes, or formats format options using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function format_options(indent : String = "  ") : Table {
        _ = indent;
        return {
            "indent" : indent,
            "newline" : "\n"
        };
    }

    --- Signature: function format(value : T, encodeFn : Function[T, String] = encoder(), options : Table = format_options()) : String
    --- Returns: String.
    --- Summary: Builds, writes, or formats format using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function format(value : T, encodeFn : Function[T, String] = encoder(), options : Table = format_options()) : String {
        return format_value(value, encodeFn, options);
    }

    --- Signature: function format_key_value_list(list : List[Table], encodeFn : Function[String, String], state : Table) : String
    --- Returns: String.
    --- Summary: Builds, writes, or formats format key value list using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function format_key_value_list(list : List[Table], encodeFn : Function[String, String], state : Table) : String {
        return format_key_value_list_checked(list, encodeFn, state)!;
    }

    --- Signature: function format_key_value_list_checked(list : List[Table], encodeFn : Function[String, String], state : Table) : Result[String, String]
    --- Returns: Result[String, String].
    --- Summary: Builds, writes, or formats format key value list checked using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function format_key_value_list_checked(list : List[Table], encodeFn : Function[String, String], state : Table) : Result[String, String] {
        local Result[String, String] encoded = encode_key_value_list_checked(list, encodeFn);
        _ = state;
        if not encoded.ok {
            return encoded;
        }

        return Ok(encoded!);
    }

    --- Signature: function format_value(value : T, encodeFn : Function[T, String], state : Table) : String
    --- Returns: String.
    --- Summary: Builds, writes, or formats format value using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function format_value(value : T, encodeFn : Function[T, String], state : Table) : String {
        _ = encodeFn;
        _ = state;
        if table_has(state, "indent") {
            return encodeFn(value);
        }

        return encodeFn(value);
    }
}
