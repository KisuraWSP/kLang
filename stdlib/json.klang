-- Typed JSON helpers backed by Klang's Go runtime parser and serializer.
-- The older String encoder functions remain as compatibility helpers.

namespace json {
    --- Parses one complete JSON value without throwing.
    function parse(source : String) : Result[JSON, String] {
        return json_parse(source);
    }

    --- Parses one complete JSON value or raises a positioned runtime error.
    function must_parse(source : String) : JSON {
        return JSON(source);
    }

    --- Serializes a JSON value to canonical compact JSON text.
    function stringify(value : JSON) : String {
        return json_stringify(value);
    }

    --- Returns an object field without raising when the field is absent.
    function get_field(value : JSON, key : String) : Option[JSON] {
        return json_get(value, key);
    }

    --- Returns an array item without raising when the index is absent.
    function get_index(value : JSON, index : Int) : Option[JSON] {
        return json_get(value, index);
    }

    --- Returns object, array, string, number, bool, or null.
    function kind(value : JSON) : String {
        return json_kind(value);
    }

    function as_string(value : JSON) : Option[String] {
        return json_string(value);
    }

    function as_int(value : JSON) : Option[Int] {
        return json_int(value);
    }

    function as_float(value : JSON) : Option[Float] {
        return json_float(value);
    }

    function as_bool(value : JSON) : Option[Bool] {
        return json_bool(value);
    }

    function is_null(value : JSON) : Bool {
        return json_is_null(value);
    }

    --- A reusable JSON null value built from a here string.
    function null_json() : JSON {
        return JSON(//
null
//);
    }

    --- Encodes an already typed JSON value.
    function encode_json(value : JSON) : String {
        return stringify(value);
    }

    --- Signature: function Null() : String
    --- Returns: String.
    --- Summary: Provides the stdlib null operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Null() : String {
        return stringify(null_json());
    }

    --- Signature: function Bool(value : Bool) : String
    --- Returns: String.
    --- Summary: Provides the stdlib bool operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Bool(value : Bool) : String {
        if value {
            return stringify(must_parse("true"));
        }
        return stringify(must_parse("false"));
    }

    --- Signature: function String(value : String) : String
    --- Returns: String.
    --- Summary: Provides the stdlib string operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function String(value : String) : String {
        return encode_binary(value);
    }

    --- Signature: function PairString(key : String, value : String) : String
    --- Returns: String.
    --- Summary: Provides the stdlib pair string operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function PairString(key : String, value : String) : String {
        return encode_binary(key) + ":" + encode_binary(value);
    }

    --- Signature: function Object1(pair : String) : String
    --- Returns: String.
    --- Summary: Provides the stdlib object1 operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Object1(pair : String) : String {
        _ = pair;
        return "{" + pair + "}";
    }

    --- Signature: function array_start_fun() : Function[String]
    --- Returns: Function[String].
    --- Summary: Provides the stdlib array start fun operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function array_start_fun() : Function[String] {
        --- Signature: function start_array() : String
        --- Returns: String.
        --- Summary: Provides the stdlib start array operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function start_array() : String {
            return "[";
        }

        return start_array;
    }

    --- Signature: function array_push_fun() : Function[String, String, String]
    --- Returns: Function[String, String, String].
    --- Summary: Provides the stdlib array push fun operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function array_push_fun() : Function[String, String, String] {
        --- Signature: function push_array_value(state : String, value : String) : String
        --- Returns: String.
        --- Summary: Combines or extends Klang value(s) for the push array value operation.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function push_array_value(state : String, value : String) : String {
            if state == "[" {
                return state + value;
            }

            return state + "," + value;
        }

        return push_array_value;
    }

    --- Signature: function array_finish_fun() : Function[String, String]
    --- Returns: Function[String, String].
    --- Summary: Provides the stdlib array finish fun operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function array_finish_fun() : Function[String, String] {
        --- Signature: function finish_array(state : String) : String
        --- Returns: String.
        --- Summary: Provides the stdlib finish array operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function finish_array(state : String) : String {
            return state + "]";
        }

        return finish_array;
    }

    --- Signature: function object_start_fun() : Function[String]
    --- Returns: Function[String].
    --- Summary: Provides the stdlib object start fun operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function object_start_fun() : Function[String] {
        --- Signature: function start_object() : String
        --- Returns: String.
        --- Summary: Provides the stdlib start object operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function start_object() : String {
            return "{";
        }

        return start_object;
    }

    --- Signature: function object_push_fun() : Function[String, String, String, String]
    --- Returns: Function[String, String, String, String].
    --- Summary: Provides the stdlib object push fun operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function object_push_fun() : Function[String, String, String, String] {
        --- Signature: function push_object_pair(state : String, key : String, value : String) : String
        --- Returns: String.
        --- Summary: Combines or extends Klang value(s) for the push object pair operation.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function push_object_pair(state : String, key : String, value : String) : String {
            local String pair = encode_binary(key) + ":" + value;
            if state == "{" {
                return state + pair;
            }

            return state + "," + pair;
        }

        return push_object_pair;
    }

    --- Signature: function object_finish_fun() : Function[String, String]
    --- Returns: Function[String, String].
    --- Summary: Provides the stdlib object finish fun operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function object_finish_fun() : Function[String, String] {
        --- Signature: function finish_object(state : String) : String
        --- Returns: String.
        --- Summary: Provides the stdlib finish object operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function finish_object(state : String) : String {
            return state + "}";
        }

        return finish_object;
    }

    --- Signature: function continuation_state(binary : String) : Table
    --- Returns: Table.
    --- Summary: Provides the stdlib continuation state operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function continuation_state(binary : String) : Table {
        _ = binary;
        return {
            "input" : binary,
            "offset" : 0,
            "done" : False,
            "value" : ""
        };
    }

    --- Signature: function decoders() : Table
    --- Returns: Table.
    --- Summary: Reads, locates, or decodes decoders from the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function decoders() : Table {
        return {
            "from_binary" : from_binary_fun(),
            "decode_value" : decode_value
        };
    }

    --- Signature: function encoder() : Function[T, String]
    --- Returns: Function[T, String].
    --- Summary: Builds, writes, or formats encoder using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function encoder() : Function[T, String] {
        --- Signature: function default_encoder(value : T) : String
        --- Returns: String.
        --- Summary: Provides the stdlib default encoder operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function default_encoder(value : T) : String {
            return value as String;
        }

        return default_encoder;
    }

    --- Signature: function formatter() : Function[T, String]
    --- Returns: Function[T, String].
    --- Summary: Builds, writes, or formats formatter using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function formatter() : Function[T, String] {
        --- Signature: function default_formatter(value : T) : String
        --- Returns: String.
        --- Summary: Provides the stdlib default formatter operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function default_formatter(value : T) : String {
