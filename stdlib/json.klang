    --- Signature: function decode_value(binary : String) : Result[String, Atom]
    --- Returns: Result[String, Atom].
    --- Summary: Reads, locates, or decodes decode value from the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function DecodeValue(binary : String) : Result[String, Atom] {
        return decode_value(binary);
    }

    @deprecated("Use DecodeValue instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function decode_value(binary : String) : Result[String, Atom] {
        if len(binary) == 0 {
            return Err(:json_value_missing);
        }

        local Result[JSON, Atom] parsed = parse(binary);
        if parsed.ok {
            return Ok(stringify(parsed.value));
        }
        return Err(:json_parse_failed);
    }

    --- Signature: function decode(binary : String, acc0 : String = "", decoderTable : Table = decoders()) : Result[String, Atom]
    --- Returns: Result[String, Atom].
    --- Summary: Reads, locates, or decodes decode from the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Decode(binary : String, acc0 : String = "", decoderTable : Table = decoders()) : Result[String, Atom] {
        return decode(binary, acc0, decoderTable);
    }

    @deprecated("Use Decode instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function decode(binary : String, acc0 : String = "", decoderTable : Table = decoders()) : Result[String, Atom] {
        local mut String input = acc0 + binary;
        if table_has(decoderTable, "from_binary") {
            local Function[String, String] fromBinary = decoderTable["from_binary"];
            input = fromBinary(input);
        }

        return decode_value(input);
    }

    --- Signature: function decode_start(binary : String, acc : String = "", decoderTable : Table = decoders()) : Table
    --- Returns: Table.
    --- Summary: Reads, locates, or decodes decode start from the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function DecodeStart(binary : String, acc : String = "", decoderTable : Table = decoders()) : Table {
        return decode_start(binary, acc, decoderTable);
    }

    @deprecated("Use DecodeStart instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function decode_start(binary : String, acc : String = "", decoderTable : Table = decoders()) : Table {
        _ = binary;
        _ = acc;
        _ = decoderTable;
        return {
            "input" : acc + binary,
            "offset" : 0,
            "done" : len(binary) != 0,
            "value" : "",
            "decoders" : decoderTable
        };
    }

    --- Signature: function decode_continue(state : Table, binary : String) : Table
    --- Returns: Table.
    --- Summary: Reads, locates, or decodes decode continue from the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function DecodeContinue(state : Table, binary : String) : Table {
