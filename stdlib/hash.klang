-- Small deterministic hash helpers.
-- These functions provide stable Klang-level digests and algorithm descriptors.
-- They are not cryptographic implementations until the runtime exposes native
-- hash primitives, but they let stdlib users build and pass hash-like values.

namespace hash {
    --- Signature: function DefaultSeed() : Int
    --- Returns: Int.
    --- Summary: Provides the stdlib default seed operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function DefaultSeed() : Int {
        return 2166136261;
    }

    --- Signature: function DefaultPrime() : Int
    --- Returns: Int.
    --- Summary: Provides the stdlib default prime operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function DefaultPrime() : Int {
        return 16777619;
    }

    --- Signature: function Normalize(value : Int) : Int
    --- Returns: Int.
    --- Summary: Provides the stdlib normalize operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Normalize(value : Int) : Int {
        if value < 0 {
            return 0 - value;
        }

        return value;
    }

    --- Signature: function Int(value : Int) : Int
    --- Returns: Int.
    --- Summary: Provides the stdlib int operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Int(value : Int) : Int {
        local mut Int result = value * 1103515245;
        result += 12345;
        return Normalize(result);
    }

    --- Signature: function Mix(seed : Int, value : Int) : Int
    --- Returns: Int.
    --- Summary: Provides the stdlib mix operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Mix(seed : Int, value : Int) : Int {
        local mut Int result = seed + value;
        result *= DefaultPrime();
        return Normalize(result);
    }

    --- Signature: function Combine(left : Int, right : Int) : Int
    --- Returns: Int.
    --- Summary: Combines or extends Klang value(s) for the combine operation.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Combine(left : Int, right : Int) : Int {
        return Int(left + (right * 31));
    }

    --- Signature: function CombineMany(values : List[Int], seed : Int = 2166136261) : Int
    --- Returns: Int.
    --- Summary: Combines or extends Klang value(s) for the combine many operation.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function CombineMany(values : List[Int], seed : Int = 2166136261) : Int {
        local mut Int result = seed;
        local mut Int index = 0;

        while index < len(values) {
            result = Mix(result, values[index]);
            index += 1;
        }

        return result;
    }

    --- Signature: function StringLengthHash(value : String) : Int
    --- Returns: Int.
    --- Summary: Provides the stdlib string length hash operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function StringLengthHash(value : String) : Int {
        return Int(len(value));
    }

    --- Signature: function StringHash(value : String, seed : Int = 2166136261) : Int
    --- Returns: Int.
    --- Summary: Provides the stdlib string hash operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function StringHash(value : String, seed : Int = 2166136261) : Int {
        local List[Char] chars = [char for char in value];
        local mut Int result = seed;
        local mut Int index = 0;

        while index < len(chars) {
            result = Mix(result, index + 1);
            index += 1;
        }

        return Mix(result, len(value));
    }

    --- Signature: function BoolHash(value : Bool) : Int
    --- Returns: Int.
    --- Summary: Provides the stdlib bool hash operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function BoolHash(value : Bool) : Int {
        if value {
            return Int(1);
        }

        return Int(0);
    }

    --- Signature: function Stable[T hashable](value : T) : Int
    --- Returns: Int.
    --- Summary: Provides the stdlib stable operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Stable[T hashable](value : T) : Int {
        if debug_type(value) == "String" {
            return StringHash(value as String);
        }

        if debug_type(value) == "Bool" {
            return BoolHash(value as Bool);
        }

        return Int(value as Int);
    }

    --- Signature: function Digest(algorithm : String, data : String, size : Int, usedforsecurity : Bool = True) : Table
    --- Returns: Table.
    --- Summary: Provides the stdlib digest operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Digest(algorithm : String, data : String, size : Int, usedforsecurity : Bool = True) : Table {
        local Int base = StringHash(data, DefaultSeed() + size);
        local Int digestValue = Mix(base, len(algorithm) + size);

        return {
            "algorithm": algorithm,
            "data": data,
            "digest": digestValue,
            "hex": digestValue as String,
            "size": size,
            "usedforsecurity": usedforsecurity
        };
    }

    --- Signature: function DigestResult(algorithm : String, data : String, size : Int, usedforsecurity : Bool = True) : Result[Table, String]
    --- Returns: Result[Table, String].
    --- Summary: Provides the stdlib digest result operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function DigestResult(algorithm : String, data : String, size : Int, usedforsecurity : Bool = True) : Result[Table, String] {
        if len(algorithm) == 0 {
            return Err("hash algorithm name cannot be empty");
        }

        if size <= 0 {
            return Err("hash digest size must be positive");
        }

        return Ok(Digest(algorithm, data, size, usedforsecurity));
    }

    --- Signature: function Hasher(algorithm : String, size : Int, usedforsecurity : Bool = True) : Function[String, Table]
    --- Returns: Function[String, Table].
    --- Summary: Checks whether hasher is true for the provided Klang value(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Hasher(algorithm : String, size : Int, usedforsecurity : Bool = True) : Function[String, Table] {
        --- Signature: function run(data : String) : Table
        --- Returns: Table.
        --- Summary: Provides the stdlib run operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function apply_digest(data : String) : Table {
            return Digest(algorithm, data, size, usedforsecurity);
        }

        return apply_digest;
    }

    --- Signature: function md5(data : String = "", usedforsecurity : Bool = True) : Table
    --- Returns: Table.
    --- Summary: Provides the stdlib md5 operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Md5(data : String = "", usedforsecurity : Bool = True) : Table {
        return md5(data, usedforsecurity);
    }

    @deprecated("Use Md5 instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function md5(data : String = "", usedforsecurity : Bool = True) : Table {
        return Digest("md5", data, 16, usedforsecurity);
    }

