-- Small deterministic hash helpers.

namespace hash {
    function Int(value : Int) : Int {
        local mut Int result = value * 1103515245;
        result += 12345;
        if result < 0 { result = result * -1; } else { result = result + 0; }
        return result;
    }

    function Combine(left : Int, right : Int) : Int {
        return Int(left + (right * 31));
    }

    function StringLengthHash(value : String) : Int {
        return Int(len(value));
    }
}
