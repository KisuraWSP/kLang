    --- Signature: function algorithms_available() : List[String]
    --- Returns: List[String].
    --- Summary: Provides the stdlib algorithms available operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function AlgorithmsAvailable() : List[String] {
        return algorithms_available();
    }

    @deprecated("Use AlgorithmsAvailable instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function algorithms_available() : List[String] {
        return ["md5", "sha1", "sha224", "sha256", "sha384", "sha512", "sha3_224", "sha3_256", "sha3_384", "sha3_512"];
    }

    --- Signature: function is_available(name : String) : Bool
    --- Returns: Bool.
    --- Summary: Checks whether is available is true for the provided Klang value(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function IsAvailable(name : String) : Bool {
        return is_available(name);
    }

    @deprecated("Use IsAvailable instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function is_available(name : String) : Bool {
        local List[String] names = algorithms_available();
        local mut Int index = 0;

        while index < len(names) {
            if names[index] == name {
                return True;
            }
            index += 1;
        }

        return False;
    }

    --- Signature: function new(name : String, data : String = "", usedforsecurity : Bool = True) : Result[Table, String]
    --- Returns: Result[Table, String].
    --- Summary: Creates or initializes new with the supplied Klang value(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function New(name : String, data : String = "", usedforsecurity : Bool = True) : Result[Table, String] {
        return new(name, data, usedforsecurity);
    }

    @deprecated("Use New instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function new(name : String, data : String = "", usedforsecurity : Bool = True) : Result[Table, String] {
        if name == "md5" {
            return Ok(md5(data, usedforsecurity));
        }
        if name == "sha1" {
            return Ok(sha1(data, usedforsecurity));
        }
        if name == "sha224" {
            return Ok(sha224(data, usedforsecurity));
        }
        if name == "sha256" {
            return Ok(sha256(data, usedforsecurity));
        }
        if name == "sha384" {
            return Ok(sha384(data, usedforsecurity));
        }
        if name == "sha512" {
            return Ok(sha512(data, usedforsecurity));
        }
        if name == "sha3_224" {
            return Ok(sha3_224(data, usedforsecurity));
        }
        if name == "sha3_256" {
            return Ok(sha3_256(data, usedforsecurity));
        }
        if name == "sha3_384" {
            return Ok(sha3_384(data, usedforsecurity));
        }
        if name == "sha3_512" {
            return Ok(sha3_512(data, usedforsecurity));
        }

        return Err("unknown hash algorithm: " + name);
    }
}
