-- HTML rendering helpers for browser and WASM-oriented Klang programs.
-- This module renders markup as strings today, while keeping small typed
-- building blocks that can grow into a templating engine later.

namespace html {
    --- Signature: function Escape(value : String) : String
    --- Returns: String.
    --- Summary: Escapes text content for safe HTML rendering.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Escape(value : String) : String {
        local mut String result = "";
        local mut Int index = 0;
        while index < len(value) {
            local Char current = value[index];
            if current == "&" {
                result += "&amp;";
            } else if current == "<" {
                result += "&lt;";
            } else if current == ">" {
                result += "&gt;";
            } else {
                result += current as String;
            }
            index += 1;
        }
        return result;
    }

    --- Signature: function EscapeAttribute(value : String) : String
    --- Returns: String.
    --- Summary: Escapes an attribute value before it is written inside quotes.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function EscapeAttribute(value : String) : String {
        return Escape(value);
    }

    --- Signature: function Text(value : String) : String
    --- Returns: String.
    --- Summary: Renders escaped text content.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Text(value : String) : String {
        return Escape(value);
    }

    --- Signature: function Raw(value : String) : String
    --- Returns: String.
    --- Summary: Renders raw HTML without escaping for trusted markup.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Raw(value : String) : String {
        return value;
    }

    --- Signature: function Attr(name : String, value : String) : String
    --- Returns: String.
    --- Summary: Renders one HTML attribute with an escaped value.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Attr(name : String, value : String) : String {
        return " " + name + "='" + EscapeAttribute(value) + "'";
    }

    --- Signature: function BoolAttr(name : String, enabled : Bool) : String
    --- Returns: String.
    --- Summary: Renders a boolean HTML attribute when enabled.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function BoolAttr(name : String, enabled : Bool) : String {
        if enabled { return " " + name; }
        return "";
    }

    --- Signature: function DataAttr(name : String, value : String) : String
    --- Returns: String.
    --- Summary: Renders a data-* attribute with an escaped value.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function DataAttr(name : String, value : String) : String {
        return Attr("data-" + name, value);
    }

    --- Signature: function Class(value : String) : String
    --- Returns: String.
    --- Summary: Renders a class attribute.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Class(value : String) : String {
        return Attr("class", value);
    }

    --- Signature: function Id(value : String) : String
    --- Returns: String.
    --- Summary: Renders an id attribute.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Id(value : String) : String {
        return Attr("id", value);
    }

    --- Signature: function Href(value : String) : String
    --- Returns: String.
    --- Summary: Renders an href attribute.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Href(value : String) : String {
        return Attr("href", value);
    }

    --- Signature: function Src(value : String) : String
    --- Returns: String.
    --- Summary: Renders a src attribute.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Src(value : String) : String {
        return Attr("src", value);
    }

    --- Signature: function Attrs(attrs : List[String]) : String
    --- Returns: String.
    --- Summary: Joins rendered attributes into one attribute string.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Attrs(attrs : List[String]) : String {
        local mut String result = "";
        local mut Int index = 0;
        while index < len(attrs) {
            result += attrs[index];
            index += 1;
        }
        return result;
    }

    --- Signature: function Fragment(children : List[String]) : String
    --- Returns: String.
    --- Summary: Joins a list of rendered child nodes without adding a wrapper tag.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Fragment(children : List[String]) : String {
        local mut String result = "";
        local mut Int index = 0;
        while index < len(children) {
            result += children[index];
            index += 1;
        }
        return result;
    }

    --- Signature: function Element(tag : String, attrs : List[String], children : String) : String
    --- Returns: String.
    --- Summary: Renders a normal HTML element with opening and closing tags.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Element(tag : String, attrs : List[String], children : String) : String {
        return "<" + tag + Attrs(attrs) + ">" + children + "</" + tag + ">";
    }

    --- Signature: function VoidElement(tag : String, attrs : List[String]) : String
    --- Returns: String.
    --- Summary: Renders a void HTML element that has no closing tag.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function VoidElement(tag : String, attrs : List[String]) : String {
        return "<" + tag + Attrs(attrs) + ">";
    }

    --- Signature: function Doctype() : String
    --- Returns: String.
    --- Summary: Renders the HTML5 document type declaration.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Doctype() : String {
        return "<!doctype html>";
    }

    --- Signature: function Document(title : String, body : String) : String
    --- Returns: String.
    --- Summary: Renders a complete HTML document with title and body content.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Document(title : String, body : String) : String {
        local String head = Head([], Title([], Text(title)));
        return Doctype() + Html([], head + Body([], body));
    }

