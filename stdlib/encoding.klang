-- Encoding helpers.
-- These are deterministic text/list transformations written in Klang syntax.
-- Host IO encoders/decoders can be added later as runtime bindings.

namespace encoding {
    --- Signature: function EncodeString(value : String) : String
    --- Returns: String.
    --- Summary: Builds, writes, or formats encode string using the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function EncodeString(value : String) : String {
        return value;
    }

    --- Signature: function DecodeString(value : String) : String
    --- Returns: String.
    --- Summary: Reads, locates, or decodes decode string from the provided Klang input(s).
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function DecodeString(value : String) : String {
        return value;
    }

    --- Signature: function Quote(value : String) : String
    --- Returns: String.
    --- Summary: Provides the stdlib quote operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Quote(value : String) : String {
        return "\"" + value + "\"";
    }

    --- Signature: function Bytes(value : String) : List[Char]
    --- Returns: List[Char].
    --- Summary: Provides the stdlib bytes operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Bytes(value : String) : List[Char] {
        return [char for char in value];
    }

    namespace ascii {
        --- Signature: function Decode(dst : String, src : String, flush : Bool = True) : Table
        --- Returns: Table.
        --- Summary: Reads, locates, or decodes decode from the provided Klang input(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function Decode(dst : String, src : String, flush : Bool = True) : Table {
            return {
                "ndst": len(dst) + len(src),
                "nsrc": len(src),
                "value": dst + src,
                "flush": flush,
                "err": ""
            };
        }

        --- Signature: function Encode(dst : String, src : String) : Int
        --- Returns: Int.
        --- Summary: Builds, writes, or formats encode using the provided Klang input(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function Encode(dst : String, src : String) : Int {
            return len(dst) + len(src);
        }

        --- Signature: function MaxEncodedLen(count : Int) : Int
        --- Returns: Int.
        --- Summary: Provides the stdlib max encoded len operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function MaxEncodedLen(count : Int) : Int {
            return count;
        }

        --- Signature: function NewDecoder(source : String) : Function[String, String]
        --- Returns: Function[String, String].
        --- Summary: Creates or initializes new decoder with the supplied Klang value(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function NewDecoder(source : String) : Function[String, String] {
            --- Signature: function decode(value : String) : String
            --- Returns: String.
            --- Summary: Reads, locates, or decodes decode from the provided Klang input(s).
            --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
            function decode(value : String) : String {
                return value;
            }

            return decode;
        }

        --- Signature: function NewEncoder(source : String) : Function[String, String]
        --- Returns: Function[String, String].
        --- Summary: Creates or initializes new encoder with the supplied Klang value(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function NewEncoder(source : String) : Function[String, String] {
            --- Signature: function encode(value : String) : String
            --- Returns: String.
            --- Summary: Builds, writes, or formats encode using the provided Klang input(s).
            --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
            function encode(value : String) : String {
                return value;
            }

            return encode;
        }

        --- Signature: function CorruptInputError(message : String) : String
        --- Returns: String.
        --- Summary: Provides the stdlib corrupt input error operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function CorruptInputError(message : String) : String {
            return "corrupt ascii input: " + message;
        }
    }

    namespace asn1 {
        --- Signature: function Marshal(value : Any) : Result[String, String]
        --- Returns: Result[String, String].
        --- Summary: Provides the stdlib marshal operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function Marshal(value : Any) : Result[String, String] {
            return Ok(debug_type(value));
        }

        --- Signature: function MarshalWithParams(value : Any, params : String) : Result[String, String]
        --- Returns: Result[String, String].
        --- Summary: Provides the stdlib marshal with params operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function MarshalWithParams(value : Any, params : String) : Result[String, String] {
            return Ok(params + ":" + debug_type(value));
        }

        --- Signature: function Unmarshal(data : String, value : Any) : Table
        --- Returns: Table.
        --- Summary: Provides the stdlib unmarshal operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function Unmarshal(data : String, value : Any) : Table {
            return {
                "rest": "",
                "value": data,
                "target_type": debug_type(value),
                "err": ""
            };
        }

        --- Signature: function UnmarshalWithParams(data : String, value : Any, params : String) : Table
        --- Returns: Table.
        --- Summary: Provides the stdlib unmarshal with params operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function UnmarshalWithParams(data : String, value : Any, params : String) : Table {
            return {
                "rest": "",
                "value": data,
                "params": params,
                "target_type": debug_type(value),
                "err": ""
            };
        }

        --- Signature: function BitAt(bits : List[Int], index : Int) : Int
        --- Returns: Int.
        --- Summary: Provides the stdlib bit at operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function BitAt(bits : List[Int], index : Int) : Int {
            if index < 0 or index >= len(bits) {
                return 0;
            }

            return bits[index];
        }

        --- Signature: function RightAlign(bits : List[Int]) : List[Int]
        --- Returns: List[Int].
        --- Summary: Provides the stdlib right align operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function RightAlign(bits : List[Int]) : List[Int] {
            return clone bits;
        }

        --- Signature: function ObjectIdentifierEqual(left : List[Int], right : List[Int]) : Bool
        --- Returns: Bool.
        --- Summary: Provides the stdlib object identifier equal operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function ObjectIdentifierEqual(left : List[Int], right : List[Int]) : Bool {
            if len(left) != len(right) {
                return False;
            }

            local mut Int index = 0;
            while index < len(left) {
                if left[index] != right[index] {
                    return False;
                }
                index += 1;
            }

            return True;
        }

        --- Signature: function ObjectIdentifierString(parts : List[Int]) : String
        --- Returns: String.
        --- Summary: Provides the stdlib object identifier string operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function ObjectIdentifierString(parts : List[Int]) : String {
            local mut String result = "";
            local mut Int index = 0;

            while index < len(parts) {
                if index == 0 {
                    result = parts[index] as String;
                } else {
                    result = result + "." + parts[index] as String;
                }
                index += 1;
            }

            return result;
        }

        --- Signature: function StructuralError(message : String) : String
        --- Returns: String.
        --- Summary: Provides the stdlib structural error operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function StructuralError(message : String) : String {
            return "asn1 structural error: " + message;
        }

        --- Signature: function SyntaxError(message : String) : String
        --- Returns: String.
        --- Summary: Provides the stdlib syntax error operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function SyntaxError(message : String) : String {
            return "asn1 syntax error: " + message;
        }
    }

    namespace base32 {
        --- Signature: function NewEncoding(alphabet : String) : Table
        --- Returns: Table.
        --- Summary: Creates or initializes new encoding with the supplied Klang value(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function NewEncoding(alphabet : String) : Table {
            return {"name": "base32", "alphabet": alphabet, "padding": "="};
        }

        --- Signature: function EncodedLen(count : Int) : Int
        --- Returns: Int.
        --- Summary: Builds, writes, or formats encoded len using the provided Klang input(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function EncodedLen(count : Int) : Int {
            return ((count + 4) / 5) * 8;
        }

        --- Signature: function DecodedLen(count : Int) : Int
        --- Returns: Int.
        --- Summary: Reads, locates, or decodes decoded len from the provided Klang input(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function DecodedLen(count : Int) : Int {
            return (count / 8) * 5;
        }

        --- Signature: function EncodeToString(src : String) : String
        --- Returns: String.
        --- Summary: Builds, writes, or formats encode to string using the provided Klang input(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function EncodeToString(src : String) : String {
            return "base32:" + src;
        }

        --- Signature: function DecodeString(src : String) : Result[String, String]
        --- Returns: Result[String, String].
        --- Summary: Reads, locates, or decodes decode string from the provided Klang input(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function DecodeString(src : String) : Result[String, String] {
            if len(src) == 0 {
                return Err("base32 input cannot be empty");
            }

            return Ok(src);
        }

        --- Signature: function WithPadding(encoding : Table, padding : String) : Table
        --- Returns: Table.
        --- Summary: Provides the stdlib with padding operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function WithPadding(encoding : Table, padding : String) : Table {
            return {"name": encoding["name"], "alphabet": encoding["alphabet"], "padding": padding};
        }
    }

    namespace base64 {
        --- Signature: function NewEncoding(alphabet : String) : Table
        --- Returns: Table.
        --- Summary: Creates or initializes new encoding with the supplied Klang value(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function NewEncoding(alphabet : String) : Table {
