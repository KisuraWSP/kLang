    namespace binary {
        --- Signature: function Size(value : Any) : Int
        --- Returns: Int.
        --- Summary: Provides the stdlib size operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function Size(value : Any) : Int {
            return len(debug_type(value));
        }

        --- Signature: function Append(buffer : List[Int], value : Int) : List[Int]
        --- Returns: List[Int].
        --- Summary: Combines or extends Klang value(s) for the append operation.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function Append(buffer : List[Int], value : Int) : List[Int] {
            local mut List[Int] result = clone buffer;
            result[len(result)] = value;
            return result;
        }

        --- Signature: function PutUvarint(buffer : List[Int], value : Int) : Int
        --- Returns: Int.
        --- Summary: Provides the stdlib put uvarint operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function PutUvarint(buffer : List[Int], value : Int) : Int {
            return len(buffer) + 1;
        }

        --- Signature: function PutVarint(buffer : List[Int], value : Int) : Int
        --- Returns: Int.
        --- Summary: Provides the stdlib put varint operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function PutVarint(buffer : List[Int], value : Int) : Int {
            return len(buffer) + 1;
        }

        --- Signature: function Uvarint(buffer : List[Int]) : Table
        --- Returns: Table.
        --- Summary: Provides the stdlib uvarint operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function Uvarint(buffer : List[Int]) : Table {
            if len(buffer) == 0 {
                return {"value": 0, "count": 0};
            }

            return {"value": buffer[0], "count": 1};
        }

        --- Signature: function Varint(buffer : List[Int]) : Table
        --- Returns: Table.
        --- Summary: Provides the stdlib varint operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function Varint(buffer : List[Int]) : Table {
            return Uvarint(buffer);
        }
    }

    namespace csv {
        --- Signature: function ParseError(message : String, line : Int = 0, column : Int = 0) : Table
        --- Returns: Table.
        --- Summary: Reads, locates, or decodes parse error from the provided Klang input(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function ParseError(message : String, line : Int = 0, column : Int = 0) : Table {
            return {"message": message, "line": line, "column": column};
        }

        --- Signature: function Error(err : Table) : String
        --- Returns: String.
        --- Summary: Provides the stdlib error operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function Error(err : Table) : String {
            return (err["message"] as String) + " at " + (err["line"] as String) + ":" + (err["column"] as String);
        }

        --- Signature: function FieldPos(field : Int) : Table
        --- Returns: Table.
        --- Summary: Provides the stdlib field pos operation using current Klang data types and runtime helpers.
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function FieldPos(field : Int) : Table {
            return {"line": 1, "column": field + 1};
        }

        --- Signature: function ReadLine(line : String) : List[String]
        --- Returns: List[String].
        --- Summary: Reads, locates, or decodes read line from the provided Klang input(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function ReadLine(line : String) : List[String] {
            return [line];
        }

        --- Signature: function Write(record : List[String]) : String
        --- Returns: String.
        --- Summary: Builds, writes, or formats write using the provided Klang input(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function Write(record : List[String]) : String {
            local mut String result = "";
            local mut Int index = 0;

            while index < len(record) {
                if index == 0 {
                    result = record[index];
                } else {
                    result = result + "," + record[index];
                }
                index += 1;
            }

            return result;
        }
    }

    namespace hex {
        --- Signature: function EncodedLen(count : Int) : Int
        --- Returns: Int.
        --- Summary: Builds, writes, or formats encoded len using the provided Klang input(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function EncodedLen(count : Int) : Int {
            return count * 2;
        }

        --- Signature: function DecodedLen(count : Int) : Int
        --- Returns: Int.
        --- Summary: Reads, locates, or decodes decoded len from the provided Klang input(s).
        --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
        function DecodedLen(count : Int) : Int {
            return count / 2;
        }

