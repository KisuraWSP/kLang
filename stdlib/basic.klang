    --- Signature: function MapInt(values : List[Int], mapper : Function[Int, Int]) : List[Int]
    --- Returns: List[Int].
    --- Summary: Provides the stdlib map int operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function MapInt(values : List[Int], mapper : Function[Int, Int]) : List[Int] {
        local mut List[Int] result;
        local mut Int index = 0;
        while index < len(values) {
            result[len(result)] = mapper(values[index]);
            index += 1;
        }
        return result;
    }

    --- Signature: function FilterInt(values : List[Int], predicate : Function[Int, Bool]) : List[Int]
    --- Returns: List[Int].
    --- Summary: Provides the stdlib filter int operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function FilterInt(values : List[Int], predicate : Function[Int, Bool]) : List[Int] {
        local mut List[Int] result;
        local mut Int index = 0;
        while index < len(values) {
            local Int value = values[index];
            if predicate(value) {
                result[len(result)] = value;
            }
            index += 1;
        }
        return result;
    }

    --- Signature: function ReduceInt(values : List[Int], initial : Int, reducer : Function[Int, Int, Int]) : Int
    --- Returns: Int.
    --- Summary: Provides the stdlib reduce int operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function ReduceInt(values : List[Int], initial : Int, reducer : Function[Int, Int, Int]) : Int {
        local mut Int total = initial;
        local mut Int index = 0;
        while index < len(values) {
            total = reducer(total, values[index]);
            index += 1;
        }
        return total;
    }

    --- Signature: function EnumerateInt(values : List[Int]) : List[Table]
    --- Returns: List[Table].
    --- Summary: Provides the stdlib enumerate int operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function EnumerateInt(values : List[Int]) : List[Table] {
        local mut List[Table] result;
        local mut Int index = 0;
        while index < len(values) {
            result[len(result)] = {"index": index, "value": values[index]};
            index += 1;
        }
        return result;
    }

