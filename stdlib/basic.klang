    }

    --- Signature: function PowInt(value : Int, exponent : Int) : Int
    --- Returns: Int.
    --- Summary: Provides the stdlib pow int operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function PowInt(value : Int, exponent : Int) : Int {
        if exponent < 0 {
            return 0;
        }
        local mut Int result = 1;
        local mut Int remaining = exponent;
        while remaining > 0 {
            result *= value;
            remaining -= 1;
        }
        return result;
    }

    --- Signature: function DivMod(left : Int, right : Int) : List[Int]
    --- Returns: List[Int].
    --- Summary: Provides the stdlib div mod operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function DivMod(left : Int, right : Int) : List[Int] {
        return [left / right, left % right];
    }

    --- Signature: function RoundFloat(value : Float) : Int
    --- Returns: Int.
    --- Summary: Provides the stdlib round float operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function RoundFloat(value : Float) : Int {
        local Int whole = value as Int;
        local Float fraction = value - (whole as Float);
        if fraction >= 0.5 {
            return whole + 1;
        }
        if fraction <= -0.5 {
            return whole - 1;
        }
        return whole;
    }

