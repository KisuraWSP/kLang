    --- Signature: function MinInt(values : List[Int]) : Option[Int]
    --- Returns: Option[Int].
    --- Summary: Provides the stdlib min int operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function MinInt(values : List[Int]) : Option[Int] {
        if len(values) == 0 {
            return None();
        }
        local mut Int best = values[0];
        local mut Int index = 1;
        while index < len(values) {
            if values[index] < best {
                best = values[index];
            }
            index += 1;
        }
        return Some(best);
    }

    --- Signature: function MaxInt(values : List[Int]) : Option[Int]
    --- Returns: Option[Int].
    --- Summary: Provides the stdlib max int operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function MaxInt(values : List[Int]) : Option[Int] {
        if len(values) == 0 {
            return None();
        }
        local mut Int best = values[0];
        local mut Int index = 1;
        while index < len(values) {
            if values[index] > best {
                best = values[index];
            }
            index += 1;
        }
        return Some(best);
    }

    --- Signature: function ReversedInt(values : List[Int]) : List[Int]
    --- Returns: List[Int].
    --- Summary: Provides the stdlib reversed int operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function ReversedInt(values : List[Int]) : List[Int] {
        local mut List[Int] result;
        local mut Int index = len(values) - 1;
        while index >= 0 {
            result[len(result)] = values[index];
            index -= 1;
        }
        return result;
    }

