    --- Signature: function ZipInt(left : List[Int], right : List[Int]) : List[Table]
    --- Returns: List[Table].
    --- Summary: Provides the stdlib zip int operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function ZipInt(left : List[Int], right : List[Int]) : List[Table] {
        local mut List[Table] result;
        local mut Int index = 0;
        local Int count = MinCount(len(left), len(right));
        while index < count {
            result[len(result)] = {"left": left[index], "right": right[index]};
            index += 1;
        }
        return result;
    }

    --- Signature: function MinCount(left : Int, right : Int) : Int
    --- Returns: Int.
    --- Summary: Provides the stdlib min count operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function MinCount(left : Int, right : Int) : Int {
        if left < right { return left; } else { return right; }
    }

    --- Signature: function MaxCount(left : Int, right : Int) : Int
