    --- Signature: function All(values : List[Bool]) : Bool
    --- Returns: Bool.
    --- Summary: Provides the stdlib all operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function All(values : List[Bool]) : Bool {
        local mut Int index = 0;
        while index < len(values) {
            if not values[index] {
                return False;
            }
            index += 1;
        }
        return True;
    }

    --- Signature: function Any(values : List[Bool]) : Bool
    --- Returns: Bool.
    --- Summary: Provides the stdlib any operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Any(values : List[Bool]) : Bool {
        local mut Int index = 0;
        while index < len(values) {
            if values[index] {
                return True;
            }
            index += 1;
        }
        return False;
    }

    --- Signature: function SumInt(values : List[Int]) : Int
