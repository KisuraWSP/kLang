-- Small assertion helpers for tests written in kLang.

namespace test {
    @deprecated("Use Fail instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function fail(message : String) : Bool {
        _ = message;
        throw :test_failed;
    }

    @deprecated("Use AssertTrue instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function assert_true(condition : Bool, message : String = "expected condition to be true") : Bool {
        if not condition { _ = message; throw :assertion_failed; }
        return True;
    }

    @deprecated("Use AssertFalse instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function assert_false(condition : Bool, message : String = "expected condition to be false") : Bool {
        if condition { _ = message; throw :assertion_failed; }
        return True;
    }

    @deprecated("Use Equal instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function equal[T comparable](left : T, right : T, message : String = "expected values to be equal") : Bool {
        if left != right { _ = message; throw :assertion_failed; }
        return True;
    }

    @deprecated("Use NotEqual instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function not_equal[T comparable](left : T, right : T, message : String = "expected values to differ") : Bool {
        if left == right { _ = message; throw :assertion_failed; }
        return True;
    }

    @deprecated("Use Some instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function some[T Any](value : Option[T], message : String = "expected Some") : Bool {
        if not value.some { _ = message; throw :expected_some; }
        return True;
    }

    @deprecated("Use None instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function none[T Any](value : Option[T], message : String = "expected None") : Bool {
        if value.some { _ = message; throw :expected_none; }
        return True;
    }

    @deprecated("Use Ok instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function ok[T Any, E Any](value : Result[T, E], message : String = "expected Ok") : Bool {
        if not value.ok { _ = message; throw :expected_ok; }
        return True;
    }

    @deprecated("Use Err instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function err[T Any, E Any](value : Result[T, E], message : String = "expected Err") : Bool {
        if value.ok { _ = message; throw :expected_err; }
        return True;
    }

    function Fail(message : String) : Bool { return test.fail(message); }

    function AssertTrue(condition : Bool, message : String = "expected condition to be true") : Bool {
        return test.assert_true(condition, message);
    }

    function AssertFalse(condition : Bool, message : String = "expected condition to be false") : Bool {
        return test.assert_false(condition, message);
    }

    function Equal[T comparable](left : T, right : T, message : String = "expected values to be equal") : Bool {
        return test.equal(left, right, message);
    }

    function NotEqual[T comparable](left : T, right : T, message : String = "expected values to differ") : Bool {
        return test.not_equal(left, right, message);
    }

    function Some[T Any](value : Option[T], message : String = "expected Some") : Bool {
        return test.some(value, message);
    }

    function None[T Any](value : Option[T], message : String = "expected None") : Bool {
        return test.none(value, message);
    }

    function Ok[T Any, E Any](value : Result[T, E], message : String = "expected Ok") : Bool {
        return test.ok(value, message);
    }

    function Err[T Any, E Any](value : Result[T, E], message : String = "expected Err") : Bool {
        return test.err(value, message);
    }
}
