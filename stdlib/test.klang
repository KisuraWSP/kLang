-- Small assertion helpers for tests written in kLang.

namespace test {
    function fail(message : String) : Bool {
        throw message;
    }

    function assert_true(condition : Bool, message : String = "expected condition to be true") : Bool {
        if not condition { throw message; }
        return True;
    }

    function assert_false(condition : Bool, message : String = "expected condition to be false") : Bool {
        if condition { throw message; }
        return True;
    }

    function equal[T comparable](left : T, right : T, message : String = "expected values to be equal") : Bool {
        if left != right { throw message; }
        return True;
    }

    function not_equal[T comparable](left : T, right : T, message : String = "expected values to differ") : Bool {
        if left == right { throw message; }
        return True;
    }

    function some[T Any](value : Option[T], message : String = "expected Some") : Bool {
        if not value.some { throw message; }
        return True;
    }

    function none[T Any](value : Option[T], message : String = "expected None") : Bool {
        if value.some { throw message; }
        return True;
    }

    function ok[T Any, E Any](value : Result[T, E], message : String = "expected Ok") : Bool {
        if not value.ok { throw message; }
        return True;
    }

    function err[T Any, E Any](value : Result[T, E], message : String = "expected Err") : Bool {
        if value.ok { throw message; }
        return True;
    }

    function Fail(message : String) : Bool { return test.fail(message); }

    function AssertTrue(condition : Bool, message : String = "expected condition to be true") : Bool {
        return test.assert_true(condition, message);
    }

    function AssertFalse(condition : Bool, message : String = "expected condition to be false") : Bool {
        return test.assert_false(condition, message);
    }

    function Equal[T comparable](left : T, right : T, message : String = "expected values to be equal") : Bool {
        return test.equal(left, right, message);
    }

    function NotEqual[T comparable](left : T, right : T, message : String = "expected values to differ") : Bool {
        return test.not_equal(left, right, message);
    }

    function Some[T Any](value : Option[T], message : String = "expected Some") : Bool {
        return test.some(value, message);
    }

    function None[T Any](value : Option[T], message : String = "expected None") : Bool {
        return test.none(value, message);
    }

    function Ok[T Any, E Any](value : Result[T, E], message : String = "expected Ok") : Bool {
        return test.ok(value, message);
    }

    function Err[T Any, E Any](value : Result[T, E], message : String = "expected Err") : Bool {
        return test.err(value, message);
    }
}
