        return take_while(values, predicate);
    }

    @deprecated("Use TakeWhile instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function take_while(values : List[T], predicate : Function[T, Bool]) : List[T] {
        local mut List[T] result;
        local mut Int index = 0;
        local mut Bool taking = True;
        while index < len(values) and taking {
            if predicate(values[index]) {
                result[len(result)] = values[index];
            } else {
                taking = False;
            }
            index += 1;
        }
        return result;
    }

