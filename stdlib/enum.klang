    --- Signature: function filter(values : List[T], predicate : Function[T, Bool]) : List[T]
    --- Returns: List[T].
    --- Summary: Provides the stdlib filter operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Filter(values : List[T], predicate : Function[T, Bool]) : List[T] {
        return values.filter(predicate).collect();
    }

    @deprecated("Use Filter instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function filter(values : List[T], predicate : Function[T, Bool]) : List[T] {
        local mut List[T] result;
        local mut Int index = 0;
        while index < len(values) {
            local T value = values[index];
            if predicate(value) {
                result[len(result)] = value;
            }
            index += 1;
        }
        return result;
    }

