        while index < len(values) {
            result[len(result)] = mapper(values[index]);
            index += 1;
        }
        return result;
    }

    --- Signature: function flat_map(values : List[T], mapper : Function[T, List[U]]) : List[U]
    --- Returns: List[U].
    --- Summary: Provides the stdlib flat map operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function FlatMap(values : List[T], mapper : Function[T, List[U]]) : List[U] {
        return flat_map(values, mapper);
    }

    @deprecated("Use FlatMap instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function flat_map(values : List[T], mapper : Function[T, List[U]]) : List[U] {
        local mut List[U] result;
        local mut Int index = 0;
        while index < len(values) {
            local List[U] mapped = mapper(values[index]);
            local mut Int innerIndex = 0;
            while innerIndex < len(mapped) {
                result[len(result)] = mapped[innerIndex];
                innerIndex += 1;
            }
            index += 1;
        }
        return result;
    }

    --- Signature: function reduce(values : List[T], initial : U, reducer : Function[U, T, U]) : U
    --- Returns: U.
    --- Summary: Provides the stdlib reduce operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Reduce(values : List[T], initial : U, reducer : Function[U, T, U]) : U {
        return values.fold(initial, reducer);
    }

    @deprecated("Use Reduce instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function reduce(values : List[T], initial : U, reducer : Function[U, T, U]) : U {
        local mut U acc = initial;
        local mut Int index = 0;
        while index < len(values) {
            acc = reducer(acc, values[index]);
            index += 1;
        }
        return acc;
    }

    --- Signature: function reverse(values : List[T]) : List[T]
    --- Returns: List[T].
    --- Summary: Provides the stdlib reverse operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
