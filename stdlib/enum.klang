    @deprecated("Use TakeEvery instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function take_every(values : List[T], nth : Int) : List[T] {
        local mut List[T] result;
        local mut Int index = 0;
        while index < len(values) {
            if index % nth == 0 {
                result[len(result)] = values[index];
            }
            index += 1;
        }
        return result;
    }

    --- Signature: function take_while(values : List[T], predicate : Function[T, Bool]) : List[T]
    --- Returns: List[T].
    --- Summary: Provides the stdlib take while operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
