    }

    @deprecated("Use CountBy instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function count_by(values : List[T], predicate : Function[T, Bool]) : Int {
        local mut Int total = 0;
        local mut Int index = 0;
        while index < len(values) {
            if predicate(values[index]) {
                total += 1;
            }
            index += 1;
        }
        return total;
    }

