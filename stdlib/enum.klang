    @deprecated("Use FetchBang instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function fetch_bang(values : List[T], position : Int) : T {
        local Option[T] found = fetch(values, position);
        if found.some {
            return found.value;
        }

        throw "enum fetch index is out of range";
    }

    --- Signature: function chunk_every(values : List[T], count : Int) : List[List[T]]
    --- Returns: List[List[T]].
    --- Summary: Provides the stdlib chunk every operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function ChunkEvery(values : List[T], count : Int) : List[List[T]] {
        return chunk_every(values, count);
    }

    @deprecated("Use ChunkEvery instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function chunk_every(values : List[T], count : Int) : List[List[T]] {
        local mut List[List[T]] chunks;
        local mut Int index = 0;

        while index < len(values) {
            local mut List[T] chunk;
            local mut Int innerIndex = 0;
            while innerIndex < count and index + innerIndex < len(values) {
                chunk[len(chunk)] = values[index + innerIndex];
                innerIndex += 1;
            }
            chunks[len(chunks)] = chunk;
            index += count;
        }

        return chunks;
    }

    --- Signature: function concat(left : List[T], right : List[T]) : List[T]
    --- Returns: List[T].
    --- Summary: Combines or extends Klang value(s) for the concat operation.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Concat(left : List[T], right : List[T]) : List[T] {
        return concat(left, right);
    }

    @deprecated("Use Concat instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function concat(left : List[T], right : List[T]) : List[T] {
        local mut List[T] result = clone left;
        local mut Int index = 0;
        while index < len(right) {
            result[len(result)] = right[index];
            index += 1;
        }
        return result;
    }

