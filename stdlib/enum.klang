    }

    @deprecated("Use Drop instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function drop(values : List[T], amount : Int) : List[T] {
        local mut List[T] result;
        local mut Int index = amount;
        while index < len(values) {
            result[len(result)] = values[index];
            index += 1;
        }
        return result;
    }

