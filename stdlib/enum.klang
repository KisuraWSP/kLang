    @deprecated("Use CountUntil instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function count_until(values : List[T], limit : Int) : Int {
        if len(values) < limit {
            return len(values);
        }
        return limit;
    }

    --- Signature: function drop(values : List[T], amount : Int) : List[T]
    --- Returns: List[T].
    --- Summary: Removes or normalizes Klang value(s) for the drop operation.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
