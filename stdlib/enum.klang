    --- Summary: Provides the stdlib acc operation using current Klang data types and runtime helpers.
    --- Contract: Preserve this typed interface when upgrading to a runtime-backed implementation.
    function Acc(value : T) : T {
        return acc(value);
    }

    @deprecated("Use Acc instead. Public stdlib functions now use UpperCamelCase for readability; this legacy spelling is retained only for source compatibility.")
    function acc(value : T) : T {
        return value;
    }

